# Caddy auto-provisions Let's Encrypt certs on first request.
# DNS A record for api.myfitz.us must point at the VPS public IP first.

api.myfitz.us {
    encode zstd gzip

    # Long timeouts so image-gen requests (can take 30-60s) aren't killed
    # while they wait on Dedalus / Higgsfield.
    reverse_proxy backend:8000 {
        transport http {
            read_timeout 180s
            write_timeout 180s
            dial_timeout 10s
        }
    }

    log {
        output stdout
        format console
    }
}

# Placeholder for the frontend once the Next.js app exists and is either
# built into a sibling container or deployed to Vercel. If you deploy the
# frontend to Vercel, delete the block below.
