# Single-host VPS setup.
# Serves the Next.js frontend and proxies backend routes under /api.

:80 {
    encode zstd gzip

    @api path /api/*
    handle_path @api {
        reverse_proxy backend:8000 {
            transport http {
                read_timeout 180s
                write_timeout 180s
                dial_timeout 10s
            }
        }
    }

    handle {
        reverse_proxy frontend:3005
    }

    log {
        output stdout
        format console
    }
}
